# Database (SQLite for local dev)
# Local dev (SQLite): DATABASE_URL="file:./dev.db"
# Production (Neon Postgres): get from Vercel → Storage → Neon integration
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/dbname?sslmode=require"

# Instagram / Meta
IG_APP_ID=
IG_APP_SECRET=
IG_REDIRECT_URI=http://localhost:3000/api/ig/callback
IG_GRAPH_VERSION=v23.0

# App URL (use ngrok URL during dev, real domain in prod)
APP_URL=http://localhost:3000

# Groq (image prompt generation) — https://console.groq.com/ (free)
GROQ_API_KEY=

# Together AI (FLUX fallback when Pollinations is rate-limited) — https://api.together.ai/
TOGETHER_API_KEY=

# Anthropic (caption generation) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Token encryption — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=
